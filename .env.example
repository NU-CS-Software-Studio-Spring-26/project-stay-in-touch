# Copy this file to .env (git-ignored) and fill in your values.
# .env is loaded automatically in development via Rails credentials or dotenv.

# ── Google Calendar OAuth 2.0 ────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Both URIs below must be added as Authorized redirect URIs in the Google Cloud Console.
# Authorized redirect URI (dev):  http://localhost:3000/google/oauth/callback
# Authorized redirect URI (prod): https://rocky-cove-15980-acbcac59777d.herokuapp.com/google/oauth/callback

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Development:
# GOOGLE_REDIRECT_URI=http://localhost:3000/google/oauth/callback
# Production (set via `heroku config:set`):
# GOOGLE_REDIRECT_URI=https://rocky-cove-15980-acbcac59777d.herokuapp.com/google/oauth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/google/oauth/callback

# ── OpenRouter AI (reconnect message suggestions) ───────────────────────────
# Get a free API key at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key
