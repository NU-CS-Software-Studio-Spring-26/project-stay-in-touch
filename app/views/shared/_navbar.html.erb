<nav class="navbar navbar-expand-lg navbar-app">
  <div class="container">
    <%= link_to "Stay In Touch", root_path, class: "navbar-brand" %>
    <button class="navbar-toggler border-0" type="button"
            data-bs-toggle="collapse" data-bs-target="#primary-nav"
            aria-controls="primary-nav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="primary-nav">
      <ul class="navbar-nav me-auto gap-1">
        <li class="nav-item">
          <%= link_to "People", people_path,
                class: "nav-link #{'active' if current_page?(people_path)}" %>
        </li>
        <li class="nav-item">
          <%= link_to "Events", events_path,
                class: "nav-link #{'active' if current_page?(events_path)}" %>
        </li>
      </ul>
      <div class="d-flex align-items-center gap-2">
        <% if authenticated? %>
          <span class="navbar-text text-muted small me-1">
            Signed in as <strong><%= current_user.email %></strong>
          </span>
          <%= link_to "Add Person", new_person_path, class: "btn btn-outline-secondary btn-sm" %>
          <%= link_to "Log Event",  new_event_path,  class: "btn btn-primary btn-sm" %>
          <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline-danger btn-sm" %>
        <% else %>
          <%= link_to "Log In",  login_path,  class: "btn btn-outline-secondary btn-sm" %>
          <%= link_to "Sign Up", signup_path, class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
