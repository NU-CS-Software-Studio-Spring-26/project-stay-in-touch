<%# ── Mobile topbar ────────────────────────────────────────── %>
<header class="mobile-topbar">
  <button class="btn p-1 border-0" type="button"
          data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar"
          aria-label="Open navigation">
    <i class="bi bi-list" style="font-size:1.4rem;"></i>
  </button>
  <span class="fw-bold d-inline-flex align-items-center gap-1" style="font-size:0.95rem;">
    <%= image_tag "serendipity-mark.svg", height: 20, alt: "" %>Serendipity
  </span>
  <% if authenticated? %>
    <%= link_to new_event_path, class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-plus"></i>
    <% end %>
  <% else %>
    <span style="width:40px;"></span>
  <% end %>
</header>

<%# ── Mobile offcanvas ─────────────────────────────────────── %>
<div class="offcanvas offcanvas-start d-lg-none"
     tabindex="-1" id="mobileSidebar"
     style="width:240px; background:#1E1B4B;">
  <div class="offcanvas-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
    <span class="d-flex align-items-center gap-2">
      <%= image_tag "serendipity-mark.svg", height: 22, alt: "" %>
      <span class="fw-bold text-white" style="font-size:0.9rem;">Serendipity</span>
    </span>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close menu"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column p-0">
    <% if authenticated? %>
      <nav class="sidebar-nav pt-2">
        <%= render "shared/sidebar_nav_links" %>
      </nav>
      <div class="mt-auto p-3">
        <%= link_to new_event_path, class: "sidebar-log-event mx-0 mb-2" do %>
          <i class="bi bi-plus-circle"></i>Log Event
        <% end %>
        <%= button_to "Log out", logout_path, method: :delete,
              class: "btn btn-sm w-100",
              style: "background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.6);border:none;" %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Desktop sidebar ─────────────────────────────────────── %>
<aside class="app-sidebar d-none d-lg-flex flex-column" aria-label="Main navigation">
  <%# Brand %>
  <%= link_to root_path, class: "sidebar-brand" do %>
    <%= image_tag "serendipity-mark.svg", height: 26, alt: "" %>
    <span class="sidebar-brand-text">Serendipity</span>
  <% end %>

  <% if authenticated? %>
    <%# Nav %>
    <nav class="sidebar-nav">
      <%= render "shared/sidebar_nav_links" %>

      <div class="sidebar-section mt-3">Settings</div>
      <%= link_to edit_settings_path, class: "sidebar-link #{request.path == edit_settings_path ? 'active' : ''}" do %>
        <i class="bi bi-gear"></i><span>Settings</span>
      <% end %>
      <%= link_to tags_path, class: "sidebar-link #{request.path.start_with?(tags_path) ? 'active' : ''}" do %>
        <i class="bi bi-tags"></i><span>Tags</span>
      <% end %>
    </nav>

    <%# Log Event CTA %>
    <%= link_to new_event_path, class: "sidebar-log-event" do %>
      <i class="bi bi-plus-circle"></i>Log Event
    <% end %>

    <%# User footer %>
    <div class="sidebar-footer">
      <div class="d-flex align-items-center gap-2">
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar, class: "avatar rounded-circle flex-shrink-0", style: "object-fit:cover;", alt: "#{current_user.display_label}'s profile photo" %>
        <% else %>
          <% nav_initials = current_user.display_label.split.first(2).map { |w| w[0].upcase }.join %>
          <span class="avatar flex-shrink-0" style="background:#4F46E5;color:#fff;font-size:0.7rem;"><%= nav_initials %></span>
        <% end %>
        <div class="flex-grow-1 min-w-0">
          <div class="fw-semibold text-truncate" style="color:#fff; font-size:0.8rem;">
            <%= current_user.email.split("@").first %>
          </div>
          <div style="font-size:0.7rem; color:rgba(255,255,255,0.35);">
            <%= current_user.email %>
          </div>
        </div>
        <%= button_to logout_path, method: :delete,
              class: "btn btn-sm flex-shrink-0",
              style: "background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.5);border:none; padding:0.3rem 0.5rem;",
              title: "Log out",
              aria: { label: "Log out" } do %>
          <i class="bi bi-box-arrow-right"></i>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="mt-auto p-3 d-flex flex-column gap-2">
      <%= link_to "Log In",  login_path,  class: "btn btn-outline-light btn-sm w-100" %>
      <%= link_to "Sign Up", signup_path, class: "btn btn-primary btn-sm w-100" %>
    </div>
  <% end %>
</aside>
