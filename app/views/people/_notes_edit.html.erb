<div class="mt-4 pt-3 border-top">
  <%= form_with model: @person, data: { turbo_frame: "notes" } do |f| %>
    <%= hidden_field_tag :inline_notes, "1" %>
    <div class="mb-2">
      <%= f.label :notes, class: "form-label fw-semibold small mb-1" %>
      <%= f.text_area :notes, rows: 4, class: "form-control", placeholder: "Add notes about #{@person.name}..." %>
    </div>
    <div class="d-flex gap-2">
      <%= f.submit "Save", class: "btn btn-sm btn-primary" %>
      <%= link_to "Cancel", notes_edit_person_path(@person, cancel: true), class: "btn btn-sm btn-outline-secondary" %>
    </div>
  <% end %>
</div>
