<%= form_with model: person, class: "vstack gap-3" do |f| %>
  <% if person.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(person.errors.count, "error") %> prevented this person from being saved:</strong>
      <ul class="mb-0"><% person.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :name, class: "form-label" do %><i class="bi bi-person me-1"></i>Name<% end %>
      <%= f.text_field :name, class: "form-control", required: true, maxlength: 255 %>
    </div>
    <div class="col-md-6">
      <%= f.label :email, class: "form-label" do %><i class="bi bi-envelope me-1"></i>Email<% end %>
      <%= f.email_field :email, class: "form-control", required: true, maxlength: 255 %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :timezone, class: "form-label" do %><i class="bi bi-globe2 me-1"></i>Timezone<% end %>
      <%= f.select :timezone,
            ActiveSupport::TimeZone::MAPPING.values.sort,
            { selected: person.timezone || "America/Chicago" },
            class: "form-select" %>
      <div class="form-text">IANA identifier (e.g., America/Chicago).</div>
    </div>
    <div class="col-md-6">
      <%= f.label :frequency_weeks, class: "form-label" do %><i class="bi bi-arrow-repeat me-1"></i>Catch up every (weeks)<% end %>
      <%= f.number_field :frequency_weeks, step: 0.5, min: 0.5, class: "form-control", required: true %>
      <div class="form-text">e.g., 2 = every 2 weeks</div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :birthday, class: "form-label" do %><i class="bi bi-cake2 me-1"></i>Birthday<% end %>
      <%= f.date_field :birthday, class: "form-control" %>
      <div class="form-text">Optional — used for birthday reminders.</div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :preferred_start_hour, class: "form-label" do %><i class="bi bi-sun me-1"></i>Preferred start time<% end %>
      <%= f.select :preferred_start_hour,
            (0..23).map { |h| [Time.new(2000, 1, 1, h).strftime("%-I %p"), h] },
            {},
            class: "form-select", required: true %>
    </div>
    <div class="col-md-6">
      <%= f.label :preferred_end_hour, class: "form-label" do %><i class="bi bi-moon me-1"></i>Preferred end time<% end %>
      <%= f.select :preferred_end_hour,
            (0..23).map { |h| [Time.new(2000, 1, 1, h).strftime("%-I %p"), h] },
            {},
            class: "form-select", required: true %>
    </div>
  </div>

  <div data-controller="char-counter" data-char-counter-max-value="5000">
    <%= f.label :notes, class: "form-label" do %><i class="bi bi-chat-text me-1"></i>Notes<% end %>
    <%= f.text_area :notes, rows: 4, class: "form-control", maxlength: 5000,
          data: { char_counter_target: "input", action: "input->char-counter#update" } %>
    <div class="form-text text-end">
      <span data-char-counter-target="count"></span>
    </div>
  </div>

  <div>
    <label class="form-label fw-semibold"><i class="bi bi-tag me-1"></i>Tags</label>
    <% if @all_tags.any? %>
      <div class="d-flex flex-wrap gap-2 mb-2">
        <% @all_tags.each do |tag| %>
          <% checked = person.tags.include?(tag) %>
          <label class="tag-checkbox-label <%= 'active' if checked %>">
            <%= f.check_box :tag_ids, { multiple: true, checked: checked, id: "tag_#{tag.id}" }, tag.id, false %>
            <%= tag.name %>
          </label>
        <% end %>
      </div>
    <% end %>
    <div class="input-group input-group-sm" style="max-width: 280px;">
      <%= f.text_field :new_tag_name, class: "form-control", placeholder: "New tag name…", maxlength: 50 %>
      <span class="input-group-text text-muted small">press Save to add</span>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", (person.persisted? ? person_path(person) : people_path),
          class: "btn btn-outline-secondary" %>
  </div>
<% end %>
