<% avatar_colors = %w[#4F46E5 #7C3AED #0D9488 #D97706 #DC2626 #2563EB #059669 #9333EA] %>

<% sort_link = ->(col, label, extra_class: "") do
  next_dir = (@sort == col && @direction == "asc") ? "desc" : "asc"
  arrow = @sort == col ? (@direction == "asc" ? " ▲" : " ▼") : ""
  active_class = @sort == col ? "active" : ""
  link_to "#{label}#{arrow}", root_path(sort: col, direction: next_dir),
    class: "sort-link #{active_class} #{extra_class}"
end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h4 mb-0 fw-bold">People</h1>
  <div class="d-flex gap-2 align-items-center">
    <% if current_user.google_calendar_connected? %>
      <span class="text-success small fw-medium">
        <i class="bi bi-check-circle-fill me-1"></i>Google Calendar connected
      </span>
      <%= button_to "Disconnect", google_oauth_disconnect_path,
            method: :delete,
            class: "btn btn-sm btn-outline-secondary",
            form: { data: { turbo_confirm: "Disconnect Google Calendar?" } } %>
    <% else %>
      <%= link_to google_oauth_authorize_path, class: "btn btn-sm btn-outline-secondary" do %>
        <i class="bi bi-google me-1"></i>Connect Google Calendar
      <% end %>
    <% end %>
    <%= link_to "Add Person", new_person_path, class: "btn btn-primary" %>
  </div>
</div>

<div data-controller="people-search">
  <div class="mb-3">
    <label for="people-search-input" class="visually-hidden">Filter people</label>
    <input type="text"
           id="people-search-input"
           class="form-control"
           placeholder="Filter by name…"
           autocomplete="off"
           data-people-search-target="input"
           data-action="input->people-search#filter"
           aria-label="Filter people">
  </div>

<turbo-frame id="people-table">
  <% if @people.empty? %>
    <div class="alert alert-info">
      No people yet. <%= link_to "Add the first one", new_person_path, class: "alert-link" %>.
    </div>
  <% else %>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead>
            <tr>
              <th><%= sort_link.call("name", "Name") %></th>
              <th class="d-none d-md-table-cell">Email</th>
              <th class="text-end"><%= sort_link.call("frequency", "Frequency") %></th>
              <th><%= sort_link.call("status", "Status") %></th>
              <th style="width: 1%;"></th>
            </tr>
          </thead>
          <tbody>
            <% @people.each do |person| %>
              <% color = avatar_colors[person.name.bytes.sum % avatar_colors.length] %>
              <% initials = person.name.split.first(2).map { |w| w[0].upcase }.join %>
              <tr data-people-search-target="row" data-name="<%= person.name %>">
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <span class="avatar" style="background: <%= color %>18; color: <%= color %>">
                      <%= initials %>
                    </span>
                    <%= link_to person.name, person_path(person),
                          class: "text-decoration-none fw-medium text-dark",
                          data: { turbo_frame: "_top" } %>
                  </div>
                </td>
                <td class="text-muted d-none d-md-table-cell">
                  <%= person.email %>
                  <%= link_to "mailto:#{person.email}", aria: { label: "Send email to #{person.email}" }, class: "ms-1 text-muted" do %>
                    <i class="bi bi-envelope" aria-hidden="true"></i>
                  <% end %>
                </td>
                <td class="text-end text-muted"><%= "every %g wk" % person.frequency_weeks %></td>
                <td>
                  <% label, css = days_until_due_badge(person.days_until_due) %>
                  <span class="badge <%= css %>"><%= label %></span>
                </td>
                <td class="text-end text-nowrap">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary px-2" type="button"
                            data-bs-toggle="dropdown" data-bs-strategy="fixed" aria-expanded="false"
                            aria-label="More options for <%= person.name %>">
                      &#8943;
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                      <li><%= link_to "View", person_path(person), class: "dropdown-item", data: { turbo_frame: "_top" } %></li>
                      <li><%= link_to "Edit", edit_person_path(person), class: "dropdown-item", data: { turbo_frame: "_top" } %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li>
                        <%= button_to "Delete", person_path(person),
                              method: :delete,
                              form: { data: { turbo_confirm: "Remove #{person.name}?" } },
                              class: "dropdown-item text-danger" %>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
  <% if @people_pagy&.pages.to_i > 1 %>
    <div class="d-flex justify-content-center mt-3">
      <%== pagy_bootstrap_nav(@people_pagy) %>
    </div>
  <% end %>
</turbo-frame>
</div>

<hr class="my-5">

<% event_sort_link = ->(col, label) do
  next_dir = (@event_sort == col && @event_direction == "desc") ? "asc" : "desc"
  arrow = @event_sort == col ? (@event_direction == "desc" ? " ▼" : " ▲") : ""
  active_class = @event_sort == col ? "active" : ""
  link_to "#{label}#{arrow}", root_path(event_sort: col, event_direction: next_dir),
    class: "sort-link #{active_class}"
end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h4 mb-0 fw-bold">Events</h2>
  <%= link_to "Log Event", new_event_path, class: "btn btn-primary" %>
</div>

<turbo-frame id="events-table">
  <% if @events.none? %>
    <div class="alert alert-info">
      No events logged yet. <%= link_to "Log your first one", new_event_path, class: "alert-link" %>.
    </div>
  <% else %>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead>
            <tr>
              <th><%= event_sort_link.call("date", "When") %></th>
              <th><%= event_sort_link.call("title", "Title") %></th>
              <th><%= event_sort_link.call("medium", "Medium") %></th>
              <th><%= event_sort_link.call("participants", "Participants") %></th>
              <th style="width: 1%;"></th>
            </tr>
          </thead>
          <tbody>
            <% @events.each do |event| %>
              <tr>
                <td class="text-nowrap text-muted"><%= l event.occurred_at, format: :datetime %></td>
                <td><%= link_to event.display_title, event_path(event), class: "text-decoration-none fw-medium text-dark" %></td>
                <td><span class="badge <%= medium_badge_class(event.medium) %>"><%= event.medium.titleize %></span></td>
                <td>
                  <%= safe_join(event.people.map { |p|
                        link_to p.name, person_path(p), class: "text-decoration-none text-muted"
                      }, ", ") %>
                </td>
                <td class="text-end text-nowrap">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary px-2" type="button"
                            data-bs-toggle="dropdown" data-bs-strategy="fixed" aria-expanded="false"
                            aria-label="More options for <%= event.display_title %>">
                      &#8943;
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                      <li><%= link_to "View", event_path(event), class: "dropdown-item" %></li>
                      <li><%= link_to "Edit", edit_event_path(event), class: "dropdown-item" %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li>
                        <%= button_to "Delete", event_path(event),
                              method: :delete,
                              form: { data: { turbo_confirm: "Remove this event?" } },
                              class: "dropdown-item text-danger" %>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
  <% if @event_pagy&.pages.to_i > 1 %>
    <div class="d-flex justify-content-center mt-3">
      <%== pagy_bootstrap_nav(@event_pagy) %>
    </div>
  <% end %>
</turbo-frame>
