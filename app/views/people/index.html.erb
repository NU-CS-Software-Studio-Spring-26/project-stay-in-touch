<% avatar_colors = %w[#4F46E5 #7C3AED #0D9488 #D97706 #DC2626 #2563EB #059669 #9333EA] %>

<% sort_link = ->(col, label, icon: nil, extra_class: "") do
  next_dir = (@sort == col && @direction == "asc") ? "desc" : "asc"
  arrow = @sort == col ? (@direction == "asc" ? " ▲" : " ▼") : ""
  active_class = @sort == col ? "active" : ""
  icon_tag = icon ? content_tag(:i, "", class: "bi #{icon} me-1") : nil
  link_to safe_join([icon_tag, label, arrow].compact), root_path(sort: col, direction: next_dir),
    class: "sort-link #{active_class} #{extra_class}"
end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h4 mb-0 fw-bold">People</h1>
  <div class="d-flex gap-2 align-items-center">
    <% if current_user.google_calendar_connected? %>
      <span class="text-success small fw-medium">
        <i class="bi bi-check-circle-fill me-1"></i>Google Calendar connected
      </span>
      <%= button_to "Disconnect", google_oauth_disconnect_path,
            method: :delete,
            class: "btn btn-sm btn-outline-secondary",
            form: { data: { turbo_confirm: "Disconnect Google Calendar?" } } %>
    <% else %>
      <%= link_to google_oauth_authorize_path, class: "btn btn-sm btn-outline-secondary" do %>
        <i class="bi bi-google me-1"></i>Connect Google Calendar
      <% end %>
    <% end %>
    <%= link_to "Import Contacts", import_people_path, class: "btn btn-outline-secondary" %>
    <%= link_to "Add Person", new_person_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @overdue_people.any? %>
  <div class="card border-warning mb-4" style="background: #FFFBEB;">
    <div class="card-body">
      <h2 class="h6 fw-semibold text-warning-emphasis mb-3">
        <i class="bi bi-clock-history me-1"></i>Time to reach out
      </h2>
      <ul class="list-unstyled mb-0 vstack gap-2">
        <% @overdue_people.each do |person| %>
          <% days_ago = ((Time.current - person.latest_event.occurred_at) / 1.day).round %>
          <li class="d-flex justify-content-between align-items-center">
            <span>
              You haven't caught up with
              <%= link_to person.name, person_path(person), class: "fw-semibold text-decoration-none" %>
              in <strong><%= days_ago %> days</strong>
              <span class="text-muted small">(every <%= "%g" % person.frequency_weeks %> <%= person.frequency_weeks == 1 ? "week" : "weeks" %>)</span>
            </span>
            <%= link_to "Log catch-up", new_event_path(person_id: person.id), class: "btn btn-sm btn-warning" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>

<%= form_with url: root_path, method: :get,
      data: { controller: "auto-submit", turbo_frame: "people-table" },
      class: "mb-3" do %>
  <label for="people-search-input" class="visually-hidden">Search people</label>
  <div class="input-group">
    <input type="text"
           id="people-search-input"
           name="q"
           value="<%= params[:q] %>"
           class="form-control"
           placeholder="Search by name…"
           autocomplete="off"
           aria-label="Search people"
           data-auto-submit-target="input"
           data-action="input->auto-submit#inputChanged">
    <button class="btn btn-outline-secondary" type="submit">
      <i class="bi bi-search"></i>
    </button>
  </div>
  <input type="hidden" name="sort" value="<%= @sort %>">
  <input type="hidden" name="direction" value="<%= @direction %>">
<% end %>

<% tag_colors = %w[#0D9488 #7C3AED #D97706 #E11D48 #2563EB #059669 #9333EA #B45309] %>
<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
  <%= link_to root_path(favorites: @favorites_filter ? nil : "1", sort: @sort, direction: @direction),
        class: "btn btn-sm #{@favorites_filter ? 'btn-warning' : 'btn-outline-secondary'}" do %>
    <i class="bi bi-star<%= '-fill' if @favorites_filter %> me-1"></i>
    <%= @favorites_filter ? "Showing favorites" : "Favorites only" %>
  <% end %>
  <% @all_tags.each_with_index do |tag, i| %>
    <% active = @tag_filter&.id == tag.id %>
    <% color = tag_colors[i % tag_colors.length] %>
    <%= link_to root_path(tag_id: active ? nil : tag.id, sort: @sort, direction: @direction, q: params[:q]),
          class: "btn btn-sm #{'btn-outline-secondary' unless active}",
          style: (active ? "background:#{color}; border-color:#{color}; color:#fff;" : nil) do %>
      <i class="bi bi-tag me-1"></i><%= tag.name %>
    <% end %>
  <% end %>
</div>

<div>

<turbo-frame id="people-table">
  <% if @people.empty? %>
    <div class="alert alert-info">
      No people yet. <%= link_to "Add the first one", new_person_path, class: "alert-link" %>.
    </div>
  <% else %>
    <div class="card" style="overflow: visible;">
      <div class="table-responsive" style="overflow: visible;">
        <table class="table table-hover mb-0 align-middle">
          <thead>
            <tr>
              <th><%= sort_link.call("name", "Name", icon: "bi-person") %></th>
              <th class="text-end"><%= sort_link.call("frequency", "Catch up every", icon: "bi-arrow-repeat") %></th>
              <th><%= sort_link.call("status", "Due", icon: "bi-clock-history") %></th>
              <th style="width: 1%;"></th>
            </tr>
          </thead>
          <tbody>
            <% @people.each do |person| %>
              <% color = avatar_colors[person.name.bytes.sum % avatar_colors.length] %>
              <% initials = person.name.split.first(2).map { |w| w[0].upcase }.join %>
              <% overdue = person.days_until_due&.negative? %>
              <tr style="<%= "box-shadow: inset 4px 0 0 #DC2626;" if overdue %>">
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <%= button_to toggle_favorite_person_path(person),
                          method: :patch,
                          class: "btn btn-sm border-0 bg-transparent p-0 me-1 flex-shrink-0",
                          aria: { label: "#{person.favorite? ? 'Unfavorite' : 'Favorite'} #{person.name}" },
                          form: { data: { turbo_frame: "_top" } } do %>
                      <i class="bi bi-star<%= '-fill text-warning' if person.favorite? %>"></i>
                    <% end %>
                    <span class="avatar" style="background: <%= color %>18; color: <%= color %>">
                      <%= initials %>
                    </span>
                    <div>
                      <%= link_to person_path(person),
                            class: "text-decoration-none fw-medium text-dark d-block",
                            data: { turbo_frame: "_top" } do %>
                        <%= highlight_match(person.name, params[:q]) %>
                      <% end %>
                      <div class="d-flex align-items-center gap-1 flex-wrap mt-1">
                        <%= link_to "mailto:#{person.email}", class: "text-muted text-decoration-none", style: "font-size:0.75rem;" do %>
                          <i class="bi bi-envelope me-1"></i><%= person.email %>
                        <% end %>
                        <% person.tags.each do |tag| %>
                          <span class="badge rounded-pill" style="background:#F3F4F6; color:#374151; font-size:0.65rem; font-weight:500;"><%= tag.name %></span>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="text-end text-muted">every <%= "%g" % person.frequency_weeks %> <%= person.frequency_weeks == 1 ? "week" : "weeks" %></td>
                <td>
                  <% label, css = days_until_due_badge(person.days_until_due) %>
                  <span class="badge <%= css %>"><%= label %></span>
                </td>
                <td class="text-end text-nowrap">
                  <div class="dropup">
                    <button class="btn btn-sm border-0 bg-transparent px-2" type="button"
                            data-bs-toggle="dropdown" data-bs-strategy="fixed" aria-expanded="false"
                            aria-label="More options for <%= person.name %>">
                      &#8943;
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                      <li><%= link_to "View", person_path(person), class: "dropdown-item", data: { turbo_frame: "_top" } %></li>
                      <li><%= link_to "Edit", edit_person_path(person), class: "dropdown-item", data: { turbo_frame: "_top" } %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li>
                        <%= button_to "Delete", person_path(person),
                              method: :delete,
                              form: { data: { turbo_confirm: "Remove #{person.name}?" } },
                              class: "dropdown-item text-danger" %>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
  <% if @people_pagy&.pages.to_i > 1 %>
    <div class="d-flex justify-content-center mt-3">
      <%== pagy_bootstrap_nav(@people_pagy) %>
    </div>
  <% end %>
</turbo-frame>
</div>
