<% content_for :title, "People" %>

<% sort_link = ->(col, label, extra_class: "") do
  next_dir = (@sort == col && @direction == "asc") ? "desc" : "asc"
  arrow = @sort == col ? (@direction == "asc" ? " ▲" : " ▼") : ""
  link_to "#{label}#{arrow}", people_path(sort: col, direction: next_dir),
    class: "text-decoration-none text-reset fw-semibold #{extra_class}"
end %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">People</h1>
  <%= link_to "Add Person", new_person_path, class: "btn btn-primary" %>
</div>

<turbo-frame id="people-table">
  <% if @people.empty? %>
    <div class="alert alert-info">
      No people yet. <%= link_to "Add the first one", new_person_path, class: "alert-link" %>.
    </div>
  <% else %>
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th><%= sort_link.call("name", "Name") %></th>
              <th>Email</th>
              <th class="text-end"><%= sort_link.call("frequency", "Frequency", extra_class: "") %></th>
              <th><%= sort_link.call("status", "Status") %></th>
              <th class="text-end" style="width: 1%;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @people.each do |person| %>
              <tr>
                <td><%= link_to person.name, person_path(person), class: "text-decoration-none", data: { turbo_frame: "_top" } %></td>
                <td class="text-muted"><%= person.email %></td>
                <td class="text-end"><%= "every %g wk" % person.frequency_weeks %></td>
                <td>
                  <% label, css = days_until_due_badge(person.days_until_due) %>
                  <span class="badge <%= css %>"><%= label %></span>
                </td>
                <td class="text-end text-nowrap">
                  <%= link_to "View", person_path(person), class: "btn btn-sm btn-outline-secondary", data: { turbo_frame: "_top" } %>
                  <%= link_to "Edit", edit_person_path(person), class: "btn btn-sm btn-outline-primary", data: { turbo_frame: "_top" } %>
                  <%= button_to "Delete", person_path(person),
                        method: :delete,
                        form: { data: { turbo_confirm: "Remove #{person.name}?" } },
                        class: "btn btn-sm btn-outline-danger d-inline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</turbo-frame>
