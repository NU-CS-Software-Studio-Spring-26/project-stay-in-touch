<% content_for :title, @person.name %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><%= link_to "People", people_path %></li>
    <li class="breadcrumb-item active" aria-current="page"><%= @person.name %></li>
  </ol>
</nav>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
      <div>
        <h1 class="h3 mb-1"><%= @person.name %></h1>
        <p class="text-muted mb-0">
          <%= mail_to @person.email %>
          &middot; <%= @person.timezone %>
        </p>
      </div>
      <div>
        <%= link_to "Edit",    edit_person_path(@person), class: "btn btn-outline-primary" %>
        <%= button_to "Delete", person_path(@person),
              method: :delete,
              form: { data: { turbo_confirm: "Remove #{@person.name}?" } },
              class: "btn btn-outline-danger d-inline" %>
      </div>
    </div>

    <dl class="row mt-4 mb-0">
      <dt class="col-sm-3">Catch up every</dt>
      <dd class="col-sm-9"><%= "%g week(s)" % @person.frequency_weeks %></dd>

      <dt class="col-sm-3">Preferred hours</dt>
      <dd class="col-sm-9"><%= "%02d:00 - %02d:00" % [@person.preferred_start_hour, @person.preferred_end_hour] %></dd>

      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <% label, css = days_until_due_badge(@person.days_until_due) %>
        <span class="badge <%= css %>"><%= label %></span>
      </dd>

      <% if @person.notes.present? %>
        <dt class="col-sm-3">Notes</dt>
        <dd class="col-sm-9"><%= simple_format(@person.notes) %></dd>
      <% end %>
    </dl>
  </div>
</div>

<% if @suggested_message.present? %>
  <div class="card shadow-sm mb-4" data-controller="clipboard">
    <div class="card-body">
      <h2 class="h6 mb-2">AI-suggested message — edit before sending.</h2>
      <textarea class="form-control mb-2" rows="3" data-clipboard-target="source"><%= @suggested_message %></textarea>
      <button class="btn btn-sm btn-outline-secondary" data-action="click->clipboard#copy">
        Copy to clipboard
      </button>
    </div>
  </div>
<% end %>

<% if current_user.google_calendar_connected? %>
  <% if @suggested_times.any? %>
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h5 mb-3">Suggested meeting times</h2>
        <ul class="list-unstyled mb-0">
          <% @suggested_times.each do |slot| %>
            <li class="mb-1">
              <span class="text-body-secondary"><%= slot.strftime("%a %b %-d") %></span>
              &middot;
              <strong><%= slot.strftime("%-I:%M %p %Z") %></strong>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card shadow-sm mb-4">
    <div class="card-body text-muted small">
      <%= link_to "Connect Google Calendar", google_oauth_authorize_path %> to see suggested meeting times.
    </div>
  </div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-2">
  <h2 class="h5 mb-0">Recent events</h2>
  <%= link_to "Log Event", new_event_path, class: "btn btn-sm btn-primary" %>
</div>

<% if @events.empty? %>
  <p class="text-muted">No events logged yet with <%= @person.name %>.</p>
<% else %>
  <ul class="list-group shadow-sm">
    <% @events.each do |event| %>
      <li class="list-group-item d-flex justify-content-between align-items-start">
        <div>
          <div>
            <%= link_to event.display_title, event_path(event), class: "fw-semibold text-decoration-none" %>
            <span class="badge <%= medium_badge_class(event.medium) %> ms-1"><%= event.medium.titleize %></span>
          </div>
          <div class="text-muted small"><%= l event.occurred_at, format: :long %></div>
        </div>
        <div class="text-end text-muted small">
          <% (event.people - [@person]).each do |other| %>
            <div>with <%= link_to other.name, person_path(other), class: "text-decoration-none" %></div>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>
