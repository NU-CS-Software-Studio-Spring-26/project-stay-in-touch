<% content_for :title, @person.name %>

<% avatar_colors = %w[#4F46E5 #7C3AED #0D9488 #D97706 #DC2626 #2563EB #059669 #9333EA] %>
<% color = avatar_colors[@person.name.bytes.sum % avatar_colors.length] %>
<% initials = @person.name.split.first(2).map { |w| w[0].upcase }.join %>
<% snoozed_label, snoozed_css = snoozed_badge(@person) if @person.snoozed? %>
<% label, css = snoozed_label ? [snoozed_label, snoozed_css] : days_until_due_badge(@person.days_until_due) %>
<% person_tz = ActiveSupport::TimeZone[@person.timezone] %>
<% user_tz   = ActiveSupport::TimeZone[current_user.timezone] %>
<% today     = Time.current.to_date %>
<% p_start   = person_tz.local(today.year, today.month, today.day, @person.preferred_start_hour) %>
<% p_end     = person_tz.local(today.year, today.month, today.day, @person.preferred_end_hour) %>

<%# ── Shared-contact banners ───────────────────────────────── %>
<% if @contact_link&.pending? && @contact_link.recipient_person == @person %>
  <div class="alert alert-info d-flex align-items-center gap-3 mb-4 flex-wrap">
    <i class="bi bi-person-plus-fill fs-4 flex-shrink-0"></i>
    <div class="flex-grow-1">
      <strong><%= @contact_link.requester_person.user.display_label %></strong>
      invited you to share contact history for <strong><%= @person.name %></strong>.
      You'll both see a combined event timeline.
    </div>
    <div class="d-flex gap-2 ms-auto flex-shrink-0">
      <%= button_to "Accept", contact_link_path(@contact_link), method: :patch,
            class: "btn btn-sm btn-primary" %>
      <%= button_to "Decline", contact_link_path(@contact_link), method: :delete,
            class: "btn btn-sm btn-outline-secondary",
            form: { data: { turbo_confirm: "Decline the shared-contact invite?" } } %>
    </div>
  </div>
<% elsif @contact_link&.pending? && @contact_link.requester_person == @person %>
  <div class="alert alert-secondary d-flex align-items-center gap-3 mb-4 flex-wrap">
    <i class="bi bi-hourglass-split flex-shrink-0"></i>
    <div class="flex-grow-1">
      Invite sent to <strong><%= @contact_link.recipient_person.user.display_label %></strong> — waiting for them to accept.
    </div>
    <%= button_to "Cancel invite", contact_link_path(@contact_link), method: :delete,
          class: "btn btn-sm btn-outline-danger ms-auto flex-shrink-0" %>
  </div>
<% elsif @contact_link&.accepted? %>
  <div class="alert alert-success d-flex align-items-center gap-3 mb-4 flex-wrap">
    <i class="bi bi-people-fill flex-shrink-0"></i>
    <div class="flex-grow-1">
      Shared with <strong><%= @linked_person.user.display_label %></strong> — combined history shown below.
    </div>
    <%= button_to "Unlink", contact_link_path(@contact_link), method: :delete,
          class: "btn btn-sm btn-outline-danger ms-auto flex-shrink-0",
          form: { data: { turbo_confirm: "Unlink shared contact? Each user will only see their own events again." } } %>
  </div>
<% end %>

<div class="d-flex align-items-center gap-2 mb-4">
  <%= link_to people_path, class: "btn-back" do %>
    <i class="bi bi-arrow-left"></i>
  <% end %>
  <span class="text-muted small">People</span>
  <i class="bi bi-chevron-right text-muted" style="font-size:0.65rem;"></i>
  <span class="small fw-semibold"><%= @person.name %></span>
</div>

<%# ── Hero card ───────────────────────────────────────────── %>
<div class="card mb-4" style="border-top: 4px solid <%= color %>;">
  <div class="card-body p-4">
    <div class="d-flex align-items-start gap-4 flex-wrap">
      <% registered_user = User.find_by(email: @person.email) %>
      <% if registered_user&.avatar&.attached? %>
        <%= image_tag registered_user.avatar, class: "avatar avatar-xl rounded-circle flex-shrink-0", style: "object-fit:cover;" %>
      <% else %>
        <span class="avatar avatar-xl flex-shrink-0" style="background: <%= color %>18; color: <%= color %>">
          <%= initials %>
        </span>
      <% end %>
      <div class="flex-grow-1">
        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
          <h1 class="h2 mb-0 fw-bold"><%= @person.name %></h1>
          <span class="badge <%= css %>"><%= label %></span>
        </div>
        <p class="text-muted mb-3">
          <%= mail_to @person.email, class: "text-muted" %>
          <span class="mx-1">&middot;</span>
          <i class="bi bi-globe2 me-1"></i><%= @person.timezone %>
          <% if @person.birthday.present? %>
            <span class="mx-1">&middot;</span>
            <i class="bi bi-cake2 me-1"></i><%= @person.birthday.strftime("%B %-d") %>
            <% days = (@person.birthday.change(year: Date.current.year) - Date.current).to_i %>
            <% days = (@person.birthday.change(year: Date.current.year + 1) - Date.current).to_i if days < 0 %>
            <% if days == 0 %>
              <span class="badge bg-warning text-dark">🎂 Today!</span>
            <% elsif days <= 14 %>
              <span class="badge" style="background:#FEF3C7;color:#92400E;">in <%= days %> days</span>
            <% end %>
          <% end %>
        </p>
        <div class="d-flex gap-2 flex-wrap">
          <span class="stat-chip">
            <i class="bi bi-arrow-repeat"></i> Every <%= "%g" % @person.frequency_weeks %> <%= @person.frequency_weeks == 1 ? "week" : "weeks" %>
          </span>
          <span class="stat-chip">
            <i class="bi bi-clock"></i>
            <%= p_start.strftime("%-I %p") %> – <%= p_end.strftime("%-I %p") %>
            (<%= person_tz.tzinfo.abbreviation %>)
            <% if person_tz.utc_offset != user_tz.utc_offset %>
              <span class="text-muted">·
                <%= p_start.in_time_zone(user_tz).strftime("%-I %p") %> – <%= p_end.in_time_zone(user_tz).strftime("%-I %p") %> your time
              </span>
            <% end %>
          </span>
        </div>

        <% all_user_tags = current_user.tags.order(:name) %>
        <% if all_user_tags.any? %>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <% all_user_tags.each do |tag| %>
              <% has_tag = @person.tags.include?(tag) %>
              <%= button_to toggle_tag_person_path(@person),
                    method: :patch,
                    params: { tag_id: tag.id },
                    class: "btn btn-sm #{has_tag ? 'btn-primary' : 'btn-outline-secondary'}",
                    aria: { label: "#{has_tag ? 'Remove' : 'Add'} tag #{tag.name}" } do %>
                <i class="bi bi-tag me-1"></i><%= tag.name %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="d-flex gap-2 flex-shrink-0 flex-wrap align-items-center">
        <%= button_to toggle_favorite_person_path(@person),
              method: :patch,
              class: "btn btn-sm #{@person.favorite? ? 'btn-warning' : 'btn-outline-secondary'}",
              aria: { label: @person.favorite? ? "Remove from favorites" : "Add to favorites" } do %>
          <i class="bi bi-star<%= '-fill' if @person.favorite? %> me-1"></i>
          <%= @person.favorite? ? "Favorited" : "Favorite" %>
        <% end %>
        <% if @person.snoozed? %>
          <%= button_to snooze_person_path(@person),
                method: :patch,
                params: { snoozed_until: "" },
                class: "btn btn-sm btn-outline-warning",
                aria: { label: "Unsnooze #{@person.name}" } do %>
            <i class="bi bi-bell me-1"></i>Unsnooze
          <% end %>
        <% end %>
        <%= form_with url: snooze_person_path(@person), method: :patch,
              class: "d-inline-flex align-items-center gap-1", data: { turbo: true } do |f| %>
          <label class="text-muted small me-1" style="white-space:nowrap;">Snooze until:</label>
          <%= f.date_field :snoozed_until, value: @person.snoozed_until,
                class: "form-control form-control-sm",
                style: "width: 140px;",
                min: Date.current.to_s %>
          <%= f.button class: "btn btn-sm #{@person.snoozed? ? 'btn-outline-secondary' : 'btn-outline-info'}" do %>
            <i class="bi bi-bell-slash me-1"></i><%= @person.snoozed? ? "Update" : "Snooze" %>
          <% end %>
        <% end %>
        <%= form_with model: @person,
              class: "d-inline-flex align-items-center gap-1", data: { turbo: true } do |f| %>
          <label class="text-muted small me-1" style="white-space:nowrap;"><i class="bi bi-cake2"></i> Birthday:</label>
          <%= f.date_field :birthday, class: "form-control form-control-sm", style: "width: 140px;" %>
          <%= f.button class: "btn btn-sm btn-outline-secondary" do %>
            Save
          <% end %>
        <% end %>
        <%= link_to "Edit", edit_person_path(@person), class: "btn btn-outline-primary btn-sm" %>
        <%= button_to "Delete", person_path(@person),
              method: :delete,
              form: { data: { turbo_confirm: "Remove #{@person.name}?" } },
              class: "btn btn-outline-danger btn-sm d-inline" %>
      </div>
    </div>

    <turbo-frame id="notes">
      <%= render "notes_display" %>
    </turbo-frame>
  </div>
</div>

<%# ── AI suggested message ────────────────────────────────── %>
<% if @suggested_message.present? %>
  <div class="card mb-4" data-controller="clipboard">
    <div class="card-body">
      <h2 class="h6 fw-semibold mb-2">
        <i class="bi bi-stars me-1 text-warning"></i>AI-suggested message — edit before sending
      </h2>
      <textarea class="form-control mb-2" rows="3" data-clipboard-target="source"><%= @suggested_message %></textarea>
      <button class="btn btn-sm btn-outline-secondary" data-action="click->clipboard#copy">
        <i class="bi bi-clipboard me-1"></i>Copy
      </button>
    </div>
  </div>
<% end %>

<turbo-frame id="quick-log-modal" class="turbo-modal" data-turbo-action="advance">
</turbo-frame>

<%# ── What I Know (person facts) ────────────────────────── %>
<%= render "person_facts/section", person: @person, facts: @facts, events: @events %>

<%# ── Suggested times ─────────────────────────────────────── %>
<% if current_user.google_calendar_connected? %>
  <% if @suggested_times.any? %>
    <div class="card mb-4">
      <div class="card-body">
        <h2 class="h6 fw-semibold mb-3">
          <i class="bi bi-calendar-check me-1 text-primary"></i>Suggested times
        </h2>
        <div class="d-flex gap-2 flex-wrap">
          <% @suggested_times.each do |slot| %>
            <a href="<%= new_event_path(person_id: @person.id, occurred_at: slot.iso8601) %>" class="slot-chip text-decoration-none" data-turbo-frame="quick-log-modal" data-turbo-action="advance">
              <div class="fw-semibold"><%= slot.strftime("%a %b %-d") %></div>
              <div class="small text-muted"><%= slot.strftime("%-I:%M %p %Z") %></div>
            </a>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card mb-4">
    <div class="card-body text-muted small">
      <i class="bi bi-calendar me-1"></i>
      <%= link_to "Connect Google Calendar", google_oauth_authorize_path %> to see suggested meeting times.
    </div>
  </div>
<% end %>

<%# ── History (own or shared) ───────────────────────────────── %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="h5 mb-0 fw-bold"><%= @linked_person ? "Shared History" : "History" %></h2>
  <%= link_to "Log Event with #{@person.name}", new_event_path(person_id: @person.id), class: "btn btn-sm btn-primary" %>
</div>

<% display_events = @shared_events || @events %>
<% if display_events.empty? %>
  <p class="text-muted">No events logged yet with <%= @person.name %>.</p>
<% else %>
  <% latest_event = display_events.first %>
  <% days_ago = ((Time.current - latest_event.occurred_at) / 1.day).round %>
  <p class="text-muted small mb-3">
    Last caught up <strong><%= days_ago %> day<%= "s" unless days_ago == 1 %> ago</strong>
    via <span class="badge <%= medium_badge_class(latest_event.medium) %>"><%= latest_event.medium.titleize %></span>
  </p>

  <div class="event-timeline">
    <% display_events.each do |event| %>
      <div class="event-timeline-item">
        <div class="event-timeline-dot" style="background: <%= color %>;"></div>
        <div class="event-timeline-body card">
          <div class="card-body py-3 px-3">
            <div class="d-flex justify-content-between align-items-start gap-2">
              <div>
                <% if event.user == current_user %>
                  <%= link_to event.display_title, event_path(event), class: "fw-semibold text-decoration-none text-dark" %>
                <% else %>
                  <span class="fw-semibold"><%= event.display_title %></span>
                <% end %>
                <span class="badge <%= medium_badge_class(event.medium) %> ms-1"><%= event.medium.titleize %></span>
                <% if @linked_person %>
                  <span class="badge bg-light text-muted border ms-1">
                    <%= event.user == current_user ? "you" : @linked_person.user.display_label %>
                  </span>
                <% end %>
                <div class="text-muted small mt-1"><%= l event.occurred_at, format: :long %></div>
                <% others = event.people - [@person, @linked_person].compact %>
                <% if others.any? %>
                  <div class="text-muted small">
                    with <%= safe_join(others.map { |p| p.user == current_user ? link_to(p.name, person_path(p), class: "text-decoration-none") : p.name }, ", ") %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Share this contact ────────────────────────────────────── %>
<% unless @contact_link %>
  <div class="card mt-4 mb-4">
    <div class="card-body">
      <h2 class="h6 fw-semibold mb-2">
        <i class="bi bi-share me-1"></i>Share this contact
      </h2>
      <p class="text-muted small mb-3">
        If another Serendipity user also knows <%= @person.name %>, link your records to see a
        combined history and co-own nudge responsibility.
      </p>
      <%= form_with url: contact_links_path, method: :post, local: true do |f| %>
        <%= f.hidden_field :person_id, value: @person.id %>
        <div class="d-flex gap-2">
          <%= f.email_field :other_user_email,
                placeholder: "Their Serendipity account email",
                class: "form-control form-control-sm",
                required: true,
                autocomplete: "off" %>
          <%= f.submit "Send invite", class: "btn btn-sm btn-outline-primary flex-shrink-0" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
