<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h6 fw-semibold mb-0">
        <i class="bi bi-journal-bookmark me-1 text-primary"></i>What I Know
      </h2>
      <% if ENV["OPENROUTER_API_KEY"].present? %>
        <%= button_to extract_person_person_facts_path(person),
              method: :post,
              class: "btn btn-sm btn-outline-warning",
              form: { data: { turbo_confirm: "Extract facts from your event notes using AI?" } } do %>
          <i class="bi bi-stars me-1"></i>Extract from notes
        <% end %>
      <% end %>
    </div>

    <% if facts.any? %>
      <div class="mb-3">
        <% facts.each do |fact| %>
          <div class="d-flex align-items-start gap-2 mb-2 p-2 rounded" style="background:#f8f9fa;">
            <span class="badge d-inline-flex align-items-center gap-1 flex-shrink-0 mt-1 <%= fact.meta[:css] %>">
              <i class="bi <%= fact.meta[:icon] %>"></i>
              <%= fact.meta[:label] %>
            </span>
            <div class="flex-grow-1 small"><%= fact.body %></div>
            <% if fact.noted_at.present? %>
              <span class="text-muted flex-shrink-0" style="font-size:0.7rem;"><%= fact.noted_at.strftime("%b %-d, %Y") %></span>
            <% end %>
            <%= button_to person_person_fact_path(person, fact),
                  method: :delete,
                  class: "btn btn-sm btn-link text-danger p-0 flex-shrink-0",
                  form: { data: { turbo_confirm: "Remove this fact?" } } do %>
              <i class="bi bi-x-lg" style="font-size:0.75rem;"></i>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted small mb-3">No facts yet — add one below or let AI extract them from your event notes.</p>
    <% end %>

    <%# Add fact inline form %>
    <%= form_with url: person_person_facts_path(person) do |f| %>
      <div class="row g-2 align-items-center">
        <div class="col-auto">
          <%= f.select "person_fact[category]",
                PersonFact::CATEGORIES.map { |c| [PersonFact::CATEGORY_META[c][:label], c] },
                {},
                class: "form-select form-select-sm" %>
        </div>
        <div class="col">
          <%= f.text_field "person_fact[body]",
                class: "form-control form-control-sm",
                placeholder: "e.g. Works as a senior PM at Google",
                maxlength: 500,
                required: true %>
        </div>
        <div class="col-auto">
          <%= f.date_field "person_fact[noted_at]",
                class: "form-control form-control-sm",
                style: "width:140px;",
                title: "Date (optional)" %>
        </div>
        <div class="col-auto">
          <%= f.submit "Add", class: "btn btn-sm btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
