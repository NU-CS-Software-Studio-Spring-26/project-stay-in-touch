<%= form_with model: event, class: "vstack gap-3" do |f| %>
  <% if event.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(event.errors.count, "error") %> prevented this event from being saved:</strong>
      <ul class="mb-0"><% event.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
    </div>
  <% end %>

  <% if event.new_record? %>
    <div>
      <span class="form-label d-block fw-semibold mb-2">When</span>
      <div class="vstack gap-1 mb-3">
        <% [["3", "In the next 3 days"], ["5", "In the next 5 days"], ["10", "In the next 10 days"], ["30", "In the next month"]].each do |val, label| %>
          <div class="form-check">
            <%= radio_button_tag "event[window_days]", val, val == "3",
                  class: "form-check-input", id: "window_#{val}" %>
            <%= label_tag "window_#{val}", label, class: "form-check-label" %>
          </div>
        <% end %>
      </div>
      <div class="row g-2">
        <div class="col">
          <label for="event_preferred_from" class="form-label small text-muted">Preferred from</label>
          <%= time_field_tag "event[preferred_from]", "09:00",
                class: "form-control", id: "event_preferred_from", autocomplete: "off" %>
        </div>
        <div class="col">
          <label for="event_preferred_to" class="form-label small text-muted">Preferred until</label>
          <%= time_field_tag "event[preferred_to]", "17:00",
                class: "form-control", id: "event_preferred_to", autocomplete: "off" %>
        </div>
      </div>
      <div class="form-text">
        We'll find the earliest open slot in your calendar within this window and time range.
      </div>
    </div>
  <% else %>
    <div>
      <%= f.label :occurred_at, "When", class: "form-label" %>
      <%= f.datetime_local_field :occurred_at,
            value: event.occurred_at.strftime("%Y-%m-%dT%H:%M"),
            class: "form-control", required: true %>
    </div>
  <% end %>

  <div>
    <%= f.label :duration_minutes, "How long?", class: "form-label fw-semibold" %>
    <%= f.select :duration_minutes,
          [["15 minutes", 15], ["30 minutes", 30], ["45 minutes", 45],
           ["1 hour", 60], ["1.5 hours", 90], ["2 hours", 120]],
          { selected: (event.duration_minutes.presence || 60) },
          class: "form-select" %>
  </div>

  <div>
    <%= f.label :medium, class: "form-label" %>
    <%= f.select :medium,
          Event::MEDIA.map { |m| [m.titleize, m] },
          { prompt: "Select a medium" },
          class: "form-select", required: true %>
  </div>

  <div>
    <%= f.label :title, "Title (optional)", class: "form-label" %>
    <%= f.text_field :title, class: "form-control",
          placeholder: "e.g., Birthday dinner", maxlength: 255 %>
    <div class="form-text">Give it a name, or leave blank and we'll figure it out.</div>
  </div>

  <fieldset>
    <legend class="form-label fw-semibold">Participants</legend>
    <% if @people.empty? %>
      <div class="alert alert-warning mb-0">
        Add a <%= link_to "Person", new_person_path, class: "alert-link" %> first.
      </div>
    <% else %>
      <div class="border rounded p-3 bg-white" style="max-height: 260px; overflow-y: auto;">
        <% @people.each do |person| %>
          <div class="form-check">
            <%= check_box_tag "event[person_ids][]", person.id,
                  event.person_ids.include?(person.id),
                  id: "event_person_ids_#{person.id}",
                  class: "form-check-input" %>
            <%= label_tag "event_person_ids_#{person.id}", person.name, class: "form-check-label" %>
          </div>
        <% end %>
      </div>
      <div class="form-text">Select every person involved — pick multiple for group catch-ups.</div>
    <% end %>
  </fieldset>

  <div>
    <%= f.label :notes, class: "form-label" %>
    <%= f.text_area :notes, rows: 4, class: "form-control",
          placeholder: "What did you talk about? Anything to follow up on?", maxlength: 5000 %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit (event.new_record? ? "Schedule Catch-Up" : "Update Event"), class: "btn btn-primary" %>
    <%= link_to "Cancel", (event.persisted? ? event_path(event) : root_path),
          class: "btn btn-outline-secondary" %>
  </div>
<% end %>
