<% content_for :title, "Events" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Events</h1>
  <%= link_to "Log Event", new_event_path, class: "btn btn-primary" %>
</div>

<% if @events.empty? %>
  <div class="alert alert-info">
    No events logged yet. <%= link_to "Log your first one", new_event_path, class: "alert-link" %>.
  </div>
<% else %>
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-striped table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>When</th>
            <th>Title</th>
            <th>Medium</th>
            <th>Participants</th>
            <th class="text-end" style="width: 1%;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <tr>
              <td class="text-nowrap"><%= l event.occurred_at.to_date %></td>
              <td><%= link_to event.display_title, event_path(event), class: "text-decoration-none" %></td>
              <td><span class="badge <%= medium_badge_class(event.medium) %>"><%= event.medium.titleize %></span></td>
              <td>
                <%= safe_join(event.people.map { |p|
                      link_to p.name, person_path(p), class: "text-decoration-none"
                    }, ", ") %>
              </td>
              <td class="text-end text-nowrap">
                <%= link_to "View",   event_path(event),      class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to "Edit",   edit_event_path(event), class: "btn btn-sm btn-outline-primary" %>
                <%= button_to "Delete", event_path(event),
                      method: :delete,
                      form: { data: { turbo_confirm: "Remove this event?" } },
                      class: "btn btn-sm btn-outline-danger d-inline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
