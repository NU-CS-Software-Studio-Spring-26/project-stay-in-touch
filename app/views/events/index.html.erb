<% content_for :title, "Events" %>

<% sort_link = ->(col, label, extra_class: "") do
  next_dir = (@sort == col && @direction == "desc") ? "asc" : "desc"
  arrow = @sort == col ? (@direction == "desc" ? " ▼" : " ▲") : ""
  active_class = @sort == col ? "active" : ""
  link_to "#{label}#{arrow}", events_path(sort: col, direction: next_dir),
    class: "sort-link #{active_class} #{extra_class}"
end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h4 mb-0 fw-bold">Events</h1>
  <%= link_to "Log Event", new_event_path, class: "btn btn-primary" %>
</div>

<div data-controller="medium-filter">
  <%= form_with url: events_path, method: :get,
        data: { controller: "auto-submit" },
        class: "mb-3" do %>
    <label for="events-search-input" class="visually-hidden">Search events</label>
    <div class="input-group">
      <input type="text"
             id="events-search-input"
             name="q"
             value="<%= params[:q] %>"
             class="form-control"
             placeholder="Search by event or person…"
             autocomplete="off"
             aria-label="Search events"
             data-auto-submit-target="input"
             data-action="input->auto-submit#inputChanged">
      <button class="btn btn-outline-secondary" type="submit">
        <i class="bi bi-search"></i>
      </button>
    </div>
    <input type="hidden" name="sort" value="<%= @sort %>">
    <input type="hidden" name="direction" value="<%= @direction %>">
  <% end %>

  <div class="d-flex flex-wrap gap-2 mb-3">
    <button class="btn btn-sm btn-outline-secondary active"
            data-medium="all"
            data-medium-filter-target="pill"
            data-action="click->medium-filter#filter">All</button>
    <% Event::MEDIA.each do |medium| %>
      <button class="btn btn-sm btn-outline-secondary"
              data-medium="<%= medium %>"
              data-medium-filter-target="pill"
              data-action="click->medium-filter#filter"><%= medium.titleize %></button>
    <% end %>
  </div>

<% if @events.none? %>
  <div class="alert alert-info">
    No events logged yet. <%= link_to "Log your first one", new_event_path, class: "alert-link" %>.
  </div>
<% else %>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead>
          <tr>
            <th><%= sort_link.call("date", "When") %></th>
            <th><%= sort_link.call("title", "Title") %></th>
            <th><%= sort_link.call("medium", "Medium") %></th>
            <th><%= sort_link.call("participants", "Participants") %></th>
            <th style="width: 1%;"></th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <tr data-medium-filter-target="row" data-medium="<%= event.medium %>">
              <td class="text-nowrap text-muted"><%= l event.occurred_at.to_date %></td>
              <td>
                <%= link_to event_path(event), class: "text-decoration-none fw-medium text-dark" do %>
                  <%= highlight_match(event.display_title, params[:q]) %>
                <% end %>
              </td>
              <td><span class="badge <%= medium_badge_class(event.medium) %>"><%= event.medium.titleize %></span></td>
              <td>
                <%= safe_join(event.people.map { |p|
                      link_to(person_path(p), class: "text-decoration-none text-muted") {
                        highlight_match(p.name, params[:q])
                      }
                    }, ", ") %>
              </td>
              <td class="text-end text-nowrap">
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary px-2" type="button"
                          data-bs-toggle="dropdown" aria-expanded="false"
                          aria-label="Options for <%= event.display_title %>">
                    &#8943;
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li><%= link_to "View", event_path(event), class: "dropdown-item" %></li>
                    <li><%= link_to "Edit", edit_event_path(event), class: "dropdown-item" %></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <%= button_to "Delete", event_path(event),
                            method: :delete,
                            form: { data: { turbo_confirm: "Remove this event?" } },
                            class: "dropdown-item text-danger" %>
                    </li>
                  </ul>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% if @pagy&.pages.to_i > 1 %>
    <div class="d-flex justify-content-center mt-3">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>
  <% end %>
<% end %>
</div>
