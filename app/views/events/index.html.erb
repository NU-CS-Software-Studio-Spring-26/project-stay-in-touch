<% content_for :title, "Events" %>

<% medium_icons = {
     "call"      => "bi-telephone",
     "video"     => "bi-camera-video",
     "coffee"    => "bi-cup-hot",
     "text"      => "bi-chat",
     "in_person" => "bi-person-walking",
     "other"     => "bi-three-dots"
   } %>
<% medium_colors = {
     "call"      => "#4338CA",
     "video"     => "#075985",
     "coffee"    => "#92400E",
     "text"      => "#374151",
     "in_person" => "#065F46",
     "other"     => "#5B21B6"
   } %>
<% avatar_colors = %w[#4F46E5 #7C3AED #0D9488 #D97706 #DC2626 #2563EB #059669 #9333EA] %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h4 mb-0 fw-bold">Events</h1>
  <%= link_to "Log Event", new_event_path, class: "btn btn-primary" %>
</div>

<%# ── Month navigator ─────────────────────────────────────── %>
<div class="card mb-4">
  <div class="card-body py-3 d-flex align-items-center justify-content-between">

    <%= link_to events_path(month: (@current_month - 1.month).strftime("%Y-%m"), q: params[:q]),
          class: "btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" do %>
      <i class="bi bi-chevron-left"></i><%= (@current_month - 1.month).strftime("%b %Y") %>
    <% end %>

    <div class="text-center">
      <div class="fw-bold"><%= @current_month.strftime("%B %Y") %></div>
      <div class="text-muted" style="font-size:0.75rem;"><%= pluralize(@events.size, "event") %></div>
      <% if @current_month == Date.current.beginning_of_month %>
        <button class="btn btn-sm btn-outline-secondary mt-1" disabled>Today</button>
      <% else %>
        <%= link_to "Today", events_path(q: params[:q]), class: "btn btn-sm btn-outline-primary mt-1" %>
      <% end %>
    </div>

    <%= link_to events_path(month: (@current_month + 1.month).strftime("%Y-%m"), q: params[:q]),
          class: "btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" do %>
      <%= (@current_month + 1.month).strftime("%b %Y") %><i class="bi bi-chevron-right"></i>
    <% end %>

  </div>
</div>

<div data-controller="medium-filter">
  <%= form_with url: events_path, method: :get,
        data: { controller: "auto-submit" },
        class: "mb-3" do %>
    <label for="events-search-input" class="visually-hidden">Search events</label>
    <div class="search-pill-wrap">
      <i class="bi bi-search search-pill-icon"></i>
      <input type="text"
             id="events-search-input"
             name="q"
             value="<%= params[:q] %>"
             class="search-pill-input"
             placeholder="Search by event or person…"
             autocomplete="off"
             aria-label="Search events"
             data-auto-submit-target="input"
             data-action="input->auto-submit#inputChanged">
    </div>
    <input type="hidden" name="month" value="<%= params[:month] %>">
  <% end %>

  <div class="d-flex flex-wrap gap-2 mb-3">
    <button class="filter-chip filter-chip-active"
            data-medium="all"
            data-medium-filter-target="pill"
            data-action="click->medium-filter#filter">
      <i class="bi bi-grid"></i>All
    </button>
    <% Event::MEDIA.each do |medium| %>
      <button class="filter-chip"
              data-medium="<%= medium %>"
              data-medium-filter-target="pill"
              data-action="click->medium-filter#filter">
        <i class="bi <%= medium_icons[medium] %>"></i><%= medium.titleize %>
      </button>
    <% end %>
  </div>

  <%# Calendar grid %>
  <% if @events.none? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-calendar-x fs-2 d-block mb-3"></i>
      <p class="mb-3">No events in <%= @current_month.strftime("%B %Y") %>. Try navigating to another month or log a new event.</p>
      <%= link_to "Log Event", new_event_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% else %>
  <% first_day   = @current_month.beginning_of_month %>
  <% last_day    = @current_month.end_of_month %>
  <% start_wday  = first_day.wday %>
  <% trailing    = (7 - last_day.wday - 1) % 7 %>

  <div class="cal-grid">
    <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |d| %>
      <div class="cal-day-header"><%= d %></div>
    <% end %>

    <% start_wday.times do %>
      <div class="cal-day cal-day--empty"></div>
    <% end %>

    <% (first_day..last_day).each do |date| %>
      <% day_events = @events_by_day[date] || [] %>
      <% is_today   = date == Date.current %>
      <div class="cal-day <%= 'cal-day--today' if is_today %>">
        <span class="cal-day-num"><%= date.day %></span>
        <% day_events.first(3).each do |event| %>
          <% accent = medium_colors[event.medium] || "#4338CA" %>
          <% people_names = event.people.map(&:name).join(", ") %>
          <% popover_html = "<div class='small'>" \
               "<div class='fw-semibold mb-1'>#{h event.display_title}</div>" \
               "<div class='text-muted mb-1'>#{h people_names}</div>" \
               "<div class='mb-1'><span class='badge #{medium_badge_class(event.medium)}'>#{event.medium.titleize}</span> " \
               "#{h event.occurred_at.strftime('%-I:%M %p · %b %-d')}</div>" \
               "#{event.notes.present? ? "<div class='text-muted fst-italic'>#{h truncate(event.notes, length: 80)}</div>" : ''}" \
               "</div>" %>
          <div class="cal-event"
               data-medium-filter-target="row"
               data-medium="<%= event.medium %>"
               data-bs-toggle="popover"
               data-bs-trigger="hover focus"
               data-bs-html="true"
               data-bs-placement="top"
               data-bs-content="<%= popover_html %>">
            <span class="cal-event-dot" style="background:<%= accent %>;"></span>
            <%= link_to truncate(event.display_title, length: 18), event_path(event),
                  class: "cal-event-title text-decoration-none",
                  style: "color:#{accent};" %>
            <div class="cal-event-people">
              <% event.people.first(2).each do |person| %>
                <% p_color    = avatar_colors[person.name.bytes.sum % avatar_colors.length] %>
                <% p_initials = person.name.split.first(2).map { |w| w[0].upcase }.join %>
                <span class="avatar d-inline-flex"
                      style="width:14px;height:14px;font-size:0.45rem;background:<%= p_color %>18;color:<%= p_color %>;">
                  <%= p_initials %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
        <% if day_events.size > 3 %>
          <% more_events = day_events.drop(3) %>
          <% more_html = "<div class='small'>" +
               more_events.map { |e|
                 "<div class='d-flex align-items-center gap-1 mb-1'>" \
                 "<span style='width:6px;height:6px;border-radius:50%;background:#{medium_colors[e.medium]};display:inline-block;flex-shrink:0;'></span>" \
                 "<span>#{h e.display_title}</span>" \
                 "<span class='text-muted ms-1'>· #{h e.people.map(&:name).join(', ')}</span>" \
                 "</div>"
               }.join +
               "</div>" %>
          <span class="cal-more"
                style="cursor:pointer;"
                data-bs-toggle="popover"
                data-bs-trigger="hover focus"
                data-bs-html="true"
                data-bs-placement="top"
                data-bs-content="<%= more_html %>">
            +<%= more_events.size %> more
          </span>
        <% end %>
      </div>
    <% end %>

    <% trailing.times do %>
      <div class="cal-day cal-day--empty"></div>
    <% end %>
  </div>
  <% end %>
</div>

<script>
  document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => {
    new bootstrap.Popover(el, { container: "body" });
  });

  document.addEventListener("keydown", function(e) {
    if (e.target.closest("input, textarea, select, [contenteditable]")) return;
    if (e.key === "ArrowLeft")  location.href = <%= events_path(month: (@current_month - 1.month).strftime('%Y-%m'), q: params[:q]).to_json %>;
    if (e.key === "ArrowRight") location.href = <%= events_path(month: (@current_month + 1.month).strftime('%Y-%m'), q: params[:q]).to_json %>;
  });
</script>
