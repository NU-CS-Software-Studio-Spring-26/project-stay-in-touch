<% if turbo_frame_request? %>
  <turbo-frame id="quick-log-modal">
    <%= render "quick_log_modal" %>
  </turbo-frame>
<% else %>
  <% content_for :title, "Log Event" %>

  <div class="d-flex align-items-center gap-3 mb-4">
    <%= link_to events_path, class: "btn-back" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <h1 class="h4 mb-0 fw-bold">Log an Event</h1>
  </div>

  <div class="card">
    <div class="card-body p-4">
      <%= render "form", event: @event %>
    </div>
  </div>
<% end %>
