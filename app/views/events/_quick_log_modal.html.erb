<% medium_icons = {
  "call" => "bi-telephone-fill",
  "video" => "bi-camera-video-fill",
  "text" => "bi-chat-fill",
  "in_person" => "bi-person-fill",
  "coffee" => "bi-cup-hot-fill",
  "other" => "bi-three-dots"
} %>

<style>turbo-frame#quick-log-modal.turbo-modal { display: flex !important; }</style>
<div class="modal-overlay">
  <div class="modal-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="fw-semibold mb-0">Log catch-up with <%= @person.name %></h5>
      <%= link_to people_path, class: "btn-close", aria: { label: "Close" } %>
    </div>

    <%= form_with model: @event, url: events_path, data: { turbo_frame: "_top" } do |f| %>
      <% if @event.errors.any? %>
        <div class="alert alert-danger">
          <strong><%= pluralize(@event.errors.count, "error") %> prevented this event from being saved:</strong>
          <ul class="mb-0"><% @event.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
        </div>
      <% end %>

      <%= hidden_field_tag "event[person_ids][]", @person.id %>
      <%= hidden_field_tag :quick_log, "1" %>

      <div class="mb-3">
        <label class="form-label fw-semibold mb-2"><i class="bi bi-chat-dots me-1"></i>Medium</label>
        <div class="d-flex flex-wrap gap-2">
          <% Event::MEDIA.each do |m| %>
            <label class="medium-pill">
              <%= f.radio_button :medium, m, class: "medium-pill-radio", required: (m == Event::MEDIA.first) %>
              <i class="bi <%= medium_icons[m] %>"></i><%= m.titleize %>
            </label>
          <% end %>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :occurred_at, class: "form-label fw-semibold" do %><i class="bi bi-calendar me-1"></i>When<% end %>
        <%= f.datetime_local_field :occurred_at,
              value: (@event.occurred_at || Time.current).strftime("%Y-%m-%dT%H:%M"),
              class: "form-control",
              required: true %>
      </div>

      <div class="mb-3" data-controller="char-counter" data-char-counter-max-value="5000">
        <%= f.label :notes, class: "form-label fw-semibold" do %><i class="bi bi-chat-text me-1"></i>Notes <span class="text-muted fw-normal">(optional)</span><% end %>
        <%= f.text_area :notes, rows: 3, class: "form-control",
              placeholder: "What did you talk about? Anything to follow up on?",
              maxlength: 5000,
              data: { char_counter_target: "input", action: "input->char-counter#update" } %>
        <div class="form-text text-end">
          <span data-char-counter-target="count"></span>
        </div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Log Catch-Up", class: "btn btn-primary" %>
        <%= link_to "Cancel", people_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
