<% content_for :title, @event.display_title %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><%= link_to "Events", events_path %></li>
    <li class="breadcrumb-item active" aria-current="page"><%= @event.display_title %></li>
  </ol>
</nav>

<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
      <div>
        <h1 class="h3 mb-1"><%= @event.display_title %></h1>
        <p class="text-muted mb-0"><%= l @event.occurred_at, format: :long %></p>
      </div>
      <div>
        <%= link_to "Edit",    edit_event_path(@event), class: "btn btn-outline-primary" %>
        <%= button_to "Delete", event_path(@event),
              method: :delete,
              form: { data: { turbo_confirm: "Remove this event?" } },
              class: "btn btn-outline-danger d-inline" %>
      </div>
    </div>

    <dl class="row mb-0">
      <dt class="col-sm-3">Medium</dt>
      <dd class="col-sm-9">
        <span class="badge <%= medium_badge_class(@event.medium) %>"><%= @event.medium.titleize %></span>
      </dd>

      <dt class="col-sm-3">Participants</dt>
      <dd class="col-sm-9">
        <% @event.people.each do |person| %>
          <%= link_to person.name, person_path(person), class: "badge bg-light text-dark border me-1 text-decoration-none" %>
        <% end %>
      </dd>

      <% if @event.notes.present? %>
        <dt class="col-sm-3">Notes</dt>
        <dd class="col-sm-9"><%= simple_format(@event.notes) %></dd>
      <% end %>
    </dl>
  </div>
</div>
