<% content_for :title, "Settings" %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <h1 class="h4 fw-bold mb-4">Settings</h1>

    <%= form_with model: current_user, url: settings_path, method: :patch, multipart: true, class: "vstack gap-3" do |f| %>
      <% if current_user.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0"><% current_user.errors.full_messages.each { |m| %><li><%= m %></li><% } %></ul>
        </div>
      <% end %>

      <div>
        <label class="form-label fw-semibold">Profile photo</label>
        <div class="d-flex align-items-center gap-3 mb-2">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "avatar avatar-xl rounded-circle", style: "object-fit:cover;", alt: "#{current_user.display_label}'s profile photo" %>
          <% else %>
            <% initials = current_user.display_label.split.first(2).map { |w| w[0].upcase }.join %>
            <span class="avatar avatar-xl" style="background:#4F46E5;color:#fff;"><%= initials %></span>
          <% end %>
        </div>
        <%= f.file_field :avatar, class: "form-control", accept: "image/png,image/jpg,image/jpeg,image/gif" %>
        <div class="form-text">PNG, JPG, or GIF · max 5 MB</div>
      </div>

      <div>
        <%= f.label :display_name, "Display name", class: "form-label fw-semibold" %>
        <%= f.text_field :display_name, class: "form-control",
              placeholder: current_user.email.split("@").first %>
        <div class="form-text">Shown to other members (and their AI secretaries) instead of your email.</div>
      </div>

      <div>
        <%= f.label :timezone, "Your timezone", class: "form-label fw-semibold" %>
        <%= f.select :timezone,
              ActiveSupport::TimeZone::MAPPING.values.sort,
              { selected: current_user.timezone },
              class: "form-select" %>
        <div class="form-text">Used to show contact availability in your local time.</div>
      </div>

      <hr class="my-1">

      <div>
        <h2 class="h6 fw-semibold mb-1"><i class="bi bi-chat-heart me-1"></i>AI Matchmaking</h2>
        <p class="text-muted small mb-2">
          Let your AI secretary set up meetings with other members. Your interests below
          are read by other opted-in members' AI secretaries when they look for matches.
        </p>

        <%= f.label :meeting_interests, "What do you want to get/receive from meetings?",
              class: "form-label fw-semibold" %>
        <%= f.text_area :meeting_interests, rows: 4, class: "form-control",
              placeholder: "e.g. Feedback on my startup idea, intros to ML researchers, a running buddy…" %>
        <div class="form-text">Plain text. Up to 2000 characters.</div>

        <div class="form-check mt-3">
          <%= f.check_box :matchmaking_enabled, class: "form-check-input" %>
          <%= f.label :matchmaking_enabled, "Enable matchmaking (opt in)", class: "form-check-label" %>
        </div>
      </div>

      <%= f.submit "Save", class: "btn btn-primary" %>
    <% end %>

    <hr class="my-4">

    <div>
      <h2 class="h6 fw-semibold mb-1"><i class="bi bi-tags me-1"></i>Tags</h2>
      <p class="text-muted small mb-2">Rename or delete the tags you use to organise your contacts.</p>
      <%= link_to "Manage Tags", tags_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>

    <hr class="my-4">

    <div>
      <h2 class="h6 fw-semibold mb-1"><i class="bi bi-calendar-check me-1"></i>Google Calendar</h2>
      <% if current_user.google_calendar_connected? %>
        <p class="text-muted small mb-2">
          New meetings are added to a dedicated <strong>Serendipity</strong> calendar in your Google
          account — Serendipity never edits your other events.
        </p>
        <% chosen = current_user.google_credential.conflict_calendar_ids %>
        <%= form_with url: google_calendar_choice_path, method: :patch, class: "vstack gap-2" do %>
          <label class="form-label fw-semibold mb-1">Check these calendars for conflicts</label>
          <% if @calendars.any? %>
            <% @calendars.each do |summary, id| %>
              <div class="form-check">
                <%= check_box_tag "availability_calendar_ids[]", id, chosen.include?(id),
                      id: "cal_#{id.parameterize}", class: "form-check-input" %>
                <%= label_tag "cal_#{id.parameterize}", summary, class: "form-check-label" %>
              </div>
            <% end %>
            <div class="form-text">
              When you schedule, Serendipity avoids busy times on the calendars you tick.
              Leave all unticked to use your primary calendar. Keep tentative or private events
              on a separate (unticked) calendar to hide them.
            </div>
          <% else %>
            <input type="hidden" name="availability_calendar_ids[]" value="">
            <p class="text-muted small mb-0">Couldn't load your calendar list right now. Try again later.</p>
          <% end %>
          <div><%= submit_tag "Save calendars", class: "btn btn-outline-secondary btn-sm mt-1" %></div>
        <% end %>
      <% else %>
        <p class="text-muted small mb-2">
          Connect Google Calendar from the <%= link_to "People page", people_path %> to let
          Serendipity schedule meetings around your availability.
        </p>
      <% end %>
    </div>

    <hr class="my-4">

    <div>
      <h2 class="h6 fw-semibold mb-1"><i class="bi bi-key me-1"></i>Change Password</h2>
      <p class="text-muted small mb-2">Update your password. You'll need to enter your current password to confirm.</p>

      <%= form_with url: change_password_settings_path, method: :patch, class: "vstack gap-3" do |f| %>
        <div>
          <label class="form-label fw-semibold" for="current_password">Current password</label>
          <div class="input-group">
            <input type="password" id="current_password" name="current_password"
                   class="form-control" autocomplete="current-password" required>
            <button class="btn btn-outline-secondary" type="button"
                    data-action="click->password-strength#toggle"
                    tabindex="-1" aria-label="Show/hide current password">
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </div>

        <div data-controller="password-strength">
          <label class="form-label fw-semibold" for="new_password">New password</label>
          <div class="input-group">
            <input type="password" id="new_password" name="new_password"
                   class="form-control" autocomplete="new-password" required
                   data-password-strength-target="input"
                   data-action="input->password-strength#check">
            <button class="btn btn-outline-secondary" type="button"
                    data-action="click->password-strength#toggle"
                    tabindex="-1" aria-label="Show/hide new password">
              <i class="bi bi-eye"></i>
            </button>
          </div>

          <ul class="list-unstyled mt-2 mb-0 small ps-1" style="line-height: 1.8">
            <li class="text-secondary" data-password-strength-target="length">
              <i class="bi bi-circle"></i> More than 10 characters
            </li>
            <li class="text-secondary" data-password-strength-target="uppercase">
              <i class="bi bi-circle"></i> At least one uppercase letter
            </li>
            <li class="text-secondary" data-password-strength-target="lowercase">
              <i class="bi bi-circle"></i> At least one lowercase letter
            </li>
            <li class="text-secondary" data-password-strength-target="number">
              <i class="bi bi-circle"></i> At least one number
            </li>
            <li class="text-secondary" data-password-strength-target="special">
              <i class="bi bi-circle"></i> At least one special character (!@#$…)
            </li>
          </ul>

          <div class="mt-3">
            <label class="form-label fw-semibold" for="new_password_confirmation">Confirm new password</label>
            <div class="input-group">
              <input type="password" id="new_password_confirmation" name="new_password_confirmation"
                     class="form-control" autocomplete="new-password" required>
              <button class="btn btn-outline-secondary" type="button"
                      data-action="click->password-strength#toggle"
                      tabindex="-1" aria-label="Show/hide confirm password">
                <i class="bi bi-eye"></i>
              </button>
            </div>
          </div>
        </div>

        <div>
          <%= f.submit "Update Password", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>

    <hr class="my-4">

    <div class="card border-danger">
      <div class="card-body">
        <h2 class="h6 fw-semibold text-danger mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Danger Zone</h2>
        <p class="text-muted small mb-3">
          Permanently delete your account and all associated data. This cannot be undone.
        </p>
        <button type="button" class="btn btn-outline-danger btn-sm"
                data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
          Delete my account
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger" id="deleteAccountModalLabel">
          <i class="bi bi-exclamation-triangle me-1"></i>Delete Account
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="<%= delete_account_path %>" method="post">
        <input type="hidden" name="_method" value="delete">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div class="modal-body">
          <p>This will permanently delete your account, contacts, events, and all other data. <strong>There is no undo.</strong></p>
          <div>
            <label class="form-label fw-semibold" for="delete_account_password">Enter your password to confirm</label>
            <input type="password" id="delete_account_password" name="password"
                   class="form-control" autocomplete="current-password" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Delete my account</button>
        </div>
      </form>
    </div>
  </div>
</div>
