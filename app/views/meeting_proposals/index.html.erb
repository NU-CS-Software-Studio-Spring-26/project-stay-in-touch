<% content_for :title, "Matches" %>

<%= turbo_stream_from current_user, :matches %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h1 class="h4 fw-bold mb-0"><i class="bi bi-chat-heart me-2"></i>Matches</h1>
  <%= button_to run_matchmaking_path, method: :post, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-magic me-1"></i>Run matchmaking now
  <% end %>
</div>

<% unless current_user.matchmaking_ready? %>
  <div class="alert alert-info">
    Matchmaking is off. Add your meeting interests and opt in on the
    <%= link_to "Settings page", edit_settings_path, class: "alert-link" %> to take part.
  </div>
<% end %>

<div id="matchmaking-status"></div>

<% if @proposals.any? %>
  <div class="list-group" id="proposals-list">
    <%= render partial: "proposal", collection: @proposals, as: :proposal %>
  </div>
<% else %>
  <div class="text-center text-muted py-5" id="proposals-list">
    <i class="bi bi-chat-heart" style="font-size:2rem;"></i>
    <p class="mt-2 mb-0">No matches yet. Opt in on Settings, then run matchmaking to see your AI secretary get to work.</p>
  </div>
<% end %>
