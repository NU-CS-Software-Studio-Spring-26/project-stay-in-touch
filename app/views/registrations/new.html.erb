<% content_for :title, "Sign Up" %>

<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h3 mb-4 text-center">Create Account</h1>

        <%= link_to google_oauth_authorize_path(mode: "signin"),
              class: "btn btn-white border w-100 d-flex align-items-center justify-content-center gap-2 mb-3",
              style: "color:#3c4043; font-weight:500" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path fill="#4285F4" d="M23.745 12.27c0-.79-.07-1.54-.19-2.27h-11.3v4.51h6.47c-.29 1.48-1.14 2.73-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.82Z"/>
            <path fill="#34A853" d="M12.255 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96h-3.98v3.09C3.515 21.3 7.615 24 12.255 24Z"/>
            <path fill="#FBBC05" d="M5.525 14.29c-.25-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29V6.62h-3.98a11.86 11.86 0 0 0 0 10.76l3.98-3.09Z"/>
            <path fill="#EA4335" d="M12.255 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42C18.205 1.19 15.495 0 12.255 0c-4.64 0-8.74 2.7-10.71 6.62l3.98 3.09c.95-2.85 3.6-4.96 6.73-4.96Z"/>
          </svg>
          Continue with Google
        <% end %>

        <div class="d-flex align-items-center gap-2 mb-3">
          <hr class="flex-grow-1 m-0">
          <span class="text-muted small px-1">or</span>
          <hr class="flex-grow-1 m-0">
        </div>

        <%= form_with model: @user, url: signup_path, class: "vstack gap-3" do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <strong><%= pluralize(@user.errors.count, "error") %>:</strong>
              <ul class="mb-0">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div>
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, required: true, autofocus: true,
                  autocomplete: "username", class: "form-control" %>
          </div>
          <div data-controller="password-strength">
            <%= f.label :password, class: "form-label" %>
            <div class="input-group">
              <%= f.password_field :password, required: true,
                    autocomplete: "new-password", class: "form-control",
                    data: { "password-strength-target": "input", action: "input->password-strength#check" } %>
              <button class="btn btn-outline-secondary" type="button"
                      data-action="click->password-strength#toggle"
                      tabindex="-1" aria-label="Show/hide password">
                <i class="bi bi-eye"></i>
              </button>
            </div>

            <ul class="list-unstyled mt-2 mb-0 small ps-1" style="line-height: 1.8">
              <li class="text-secondary" data-password-strength-target="length">
                <i class="bi bi-circle"></i> More than 10 characters
              </li>
              <li class="text-secondary" data-password-strength-target="uppercase">
                <i class="bi bi-circle"></i> At least one uppercase letter
              </li>
              <li class="text-secondary" data-password-strength-target="lowercase">
                <i class="bi bi-circle"></i> At least one lowercase letter
              </li>
              <li class="text-secondary" data-password-strength-target="number">
                <i class="bi bi-circle"></i> At least one number
              </li>
              <li class="text-secondary" data-password-strength-target="special">
                <i class="bi bi-circle"></i> At least one special character (!@#$…)
              </li>
            </ul>

            <div class="mt-3">
              <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
              <div class="input-group">
                <%= f.password_field :password_confirmation, required: true,
                      autocomplete: "new-password", class: "form-control" %>
                <button class="btn btn-outline-secondary" type="button"
                        data-action="click->password-strength#toggle"
                        tabindex="-1" aria-label="Show/hide confirm password">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
            </div>
          </div>
          <%= f.submit "Sign Up", class: "btn btn-primary w-100" %>
        <% end %>
        <hr>
        <p class="text-center mb-0 small">
          Already have an account? <%= link_to "Log in", login_path %>
        </p>
      </div>
    </div>
  </div>
</div>
