# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database and its supporting files.
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore compiled assets.
/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore test coverage reports.
/coverage/

# Ignore generated RDoc API documentation (regenerate with `rails rdoc`).
# This is the singular doc/ output dir; the committed docs/ markdown is separate.
/doc/

# Ignore environment files and local overrides.
.env
.env.*
!.env.example

# Claude Code local settings (machine-specific).
.claude/

# macOS metadata.
.DS_Store

# Editor and OS swap files.
*.swp
*.swo
*~

# Bundler cache (should be regenerated per machine).
/vendor/bundle

# Node (if ever used).
/node_modules
/yarn-error.log

CLAUDE.md
git

# Personal milestone files (not for the repo).
/milestone3-checklist.md
/Spring 26 Milestone 4 and final exam presentation.md