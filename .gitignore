# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database and its supporting files.
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore compiled assets.
/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore test coverage reports.
/coverage/

# Ignore environment files and local overrides.
.env
.env.*
!.env.example

# macOS metadata.
.DS_Store

# Editor and OS swap files.
*.swp
*.swo
*~

# Bundler cache (should be regenerated per machine).
/vendor/bundle

# Node (if ever used).
/node_modules
/yarn-error.log

# Personal Claude Code settings (per-user overrides).
/.claude/settings.local.json
